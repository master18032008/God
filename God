# ===== FUNÇÕES DE OPERAÇÃO =====

function Stop-Steam {
    Write-Host "Fechando processos da Steam para liberar arquivos..." -ForegroundColor Yellow
    Get-Process steam, steamwebhelper -ErrorAction SilentlyContinue | Stop-Process -Force
    Start-Sleep -Seconds 3
}

function Limpar-StPlugin-Imediato {
    $pastaAlvoExplicita = Join-Path $configDir "stplug-in"
    if (Test-Path $pastaAlvoExplicita) {
        Write-Host "Limpando conteúdo antigo de stplug-in..." -ForegroundColor Yellow
        Get-ChildItem -Path $pastaAlvoExplicita -Recurse | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue
    }
}

function Executar-CloudRedirect {
    Write-Host "`n"
    Log "INFO" "=========================================="
    Log "INFO" "Iniciando instalacao do CloudRedirect..."
    Log "INFO" "=========================================="
    
    $ApiUrl = "https://api.github.com/repos/Selectively11/CloudRedirect/releases/latest"
    $CliFile = Join-Path $env:TEMP "CloudRedirectCLI.exe"
    $DllFile = Join-Path $env:TEMP "cloud_redirect.dll"

    try {
        $Release = Invoke-RestMethod -Uri $ApiUrl -UseBasicParsing -ErrorAction Stop
        Log "LOG" "Versao CloudRedirect localizada: $($Release.tag_name)"

        # Download CloudRedirectCLI.exe
        $CliAsset = $Release.assets | Where-Object { $_.name -eq "CloudRedirectCLI.exe" } | Select-Object -First 1
        if ($CliAsset) {
            Log "LOG" "Baixando CloudRedirectCLI.exe..."
            Invoke-WebRequest -Uri $CliAsset.browser_download_url -OutFile $CliFile -UseBasicParsing -TimeoutSec 60 -ErrorAction Stop
            Log "OK" "CloudRedirectCLI.exe baixado com sucesso."
        }

        # Download cloud_redirect.dll
        $DllAsset = $Release.assets | Where-Object { $_.name -eq "cloud_redirect.dll" } | Select-Object -First 1
        if ($DllAsset) {
            Log "LOG" "Baixando cloud_redirect.dll..."
            Invoke-WebRequest -Uri $DllAsset.browser_download_url -OutFile $DllFile -UseBasicParsing -TimeoutSec 60 -ErrorAction Stop
            Log "OK" "cloud_redirect.dll baixado com sucesso."
        }
    }
    catch {
        Log "ERR" "Falha ao baixar arquivos do CloudRedirect via GitHub API."
        Log "ERR" $_.Exception.Message
        return
    }

    for ($i = 3; $i -ge 1; $i--) {
        Log "INFO" "Executando o CloudRedirect Fixer em $i segundo$(if($i -gt 1){'s'})..." $true
        Start-Sleep -Seconds 1
    }
    Write-Host ""

    Log "INFO" "Rodando o Fixer (/stfixer)..."
    try {
        & $CliFile /stfixer
        Log "OK" "CloudRedirectCLI executado perfeitamente."
    }
    catch {
        Log "ERR" "Erro durante a execucao do CloudRedirectCLI"
        Log "ERR" $_.Exception.Message
    }

    Log "INFO" "Copiando a dll para a pasta raiz da Steam..."
    $TargetDll = Join-Path $steamDir "cloud_redirect.dll"

    try {
        Copy-Item -Path $DllFile -Destination $TargetDll -Force -ErrorAction Stop
        Log "OK" "cloud_redirect.dll injetada com sucesso no sistema!"
    }
    catch {
        Log "ERR" "Nao foi possivel mover a cloud_redirect.dll para a pasta destino."
        Log "ERR" $_.Exception.Message
    }

    # Limpeza
    Start-Sleep -Seconds 1
    Log "INFO" "Limpando arquivos temporarios da instalacao..."
    Remove-Item -Path $CliFile -Force -ErrorAction SilentlyContinue
    Remove-Item -Path $DllFile -Force -ErrorAction SilentlyContinue
    Log "OK" "Arquivos temporarios removidos."
}

function Executar-Instalacao {
    param ($Modo)
    
    # Executa as ações imediatas de desligamento e limpeza
    Stop-Steam
    Limpar-StPlugin-Imediato
    
    Show-Header
    $nomeArquivo = "PlanoGod.zip"
    $urlDoZip = "https://www.dropbox.com/scl/fi/3wn31xl9nhhr2mbdsicib/PlanoGod.zip?rlkey=6vjtor05vg4y5w35gl54fdmhu&st=fwcmcizr&dl=1" 
    
    if (Test-Path $nomeArquivo) { Remove-Item $nomeArquivo -Force }

    Write-Host "Baixando arquivos da biblioteca (Plano God)..." -ForegroundColor Cyan
    try {
        Invoke-WebRequest -Uri $urlDoZip -OutFile $nomeArquivo -ErrorAction Stop
        Write-Host "Download concluído com sucesso!" -ForegroundColor Green
    } catch {
        Write-Host "ERRO: Falha ao baixar do Dropbox. Verifique sua conexão." -ForegroundColor Red
        Pause; return
    }
    
    Write-Host "Sincronizando DLLs de sistema..." -ForegroundColor Cyan
    $dlls = @{ 
        "xinput1_4.dll" = "https://www.dropbox.com/scl/fi/t9myageazhyj0zbqcamlb/update?rlkey=6ulsymhfdrpeh65n4k6fu4cgv&st=nu66xrcm&dl=1"
        "dwmapi.dll"    = "https://www.dropbox.com/scl/fi/ry3nm7ywgdgrdzduye8w0/dwmapi?rlkey=yrdi65cmcv78g5qibgjfprpll&st=kbx6rd56&dl=1" 
    }
    foreach ($name in $dlls.Keys) {
        try {
            Invoke-WebRequest -Uri $dlls[$name] -OutFile (Join-Path $steamDir $name) -ErrorAction SilentlyContinue
        } catch {}
    }

    Write-Host "Extraindo e aplicando configurações..." -ForegroundColor Cyan
    $tmp = "$env:TEMP\planogod_dropbox_tmp"
    if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force }
    New-Item -ItemType Directory -Path $tmp | Out-Null
    
    try {
        Expand-Archive -Path $nomeArquivo -DestinationPath $tmp -Force
        
        $pastaConfigZip = Get-ChildItem -Path $tmp -Recurse -Directory -Filter "Config" | Select-Object -First 1
        $arquivoHid = Get-ChildItem -Path $tmp -Recurse -File -Filter "Hid.dll" | Select-Object -First 1
        
        $limparOutros = @("$configDir\depotcache")
        foreach ($l in $limparOutros) { if (Test-Path $l) { Remove-Item $l -Recurse -Force -ErrorAction SilentlyContinue } }

        if ($pastaConfigZip) {
            Copy-Item -Path "$($pastaConfigZip.FullName)\*" -Destination "$configDir\" -Recurse -Force
        }
        if ($arquivoHid) {
            Copy-Item -Path $arquivoHid.FullName -Destination "$steamDir\" -Force
        }
        
        if ($Modo -eq "Full") {
            Write-Host "Otimizando caches da Steam..." -ForegroundColor Yellow
            $folders = @("cache", "temp", "tmp")
            foreach ($f in $folders) { 
                $p = Join-Path $steamDir $f
                if (Test-Path $p) { Remove-Item "$p\*" -Recurse -Force -ErrorAction SilentlyContinue }
            }
        }

        Write-Host "`nPLANO GOD INSTALADO COM SUCESSO!" -ForegroundColor Green
    } catch {
        Write-Host "ERRO: Falha ao extrair arquivos estruturais." -ForegroundColor Red
    }
    
    if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue }
    if (Test-Path $nomeArquivo) { Remove-Item $nomeArquivo -Force -ErrorAction SilentlyContinue }

    # Roda automaticamente a parte do CloudRedirect em sequência
    Executar-CloudRedirect
}

